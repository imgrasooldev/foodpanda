# --- App ---
NODE_ENV=development
PORT=4000
API_PREFIX=api

# --- Database ---
DATABASE_URL="postgresql://foodrush:foodrush@localhost:5432/foodrush?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_ACCESS_SECRET="change-me-access-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_REFRESH_TTL="30d"

# --- OTP (SMS) ---
# In dev, OTPs are logged to the console instead of sent.
OTP_TTL_SECONDS=300
OTP_DEV_MODE=true

# --- CORS ---
CORS_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"
